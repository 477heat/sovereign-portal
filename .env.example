NEXT_PUBLIC_THIRDWEB_CLIENT_ID=
NEXT_PUBLIC_PORTAL_PREVIEW_SHELL=false

# Keep mock until the image + metadata upload pipeline is returning final IPFS image URIs.
PORTAL_MINT_MODE=mock

# Server-only backend endpoints. Never expose these with NEXT_PUBLIC_.
PORTAL_ENGINE_URL=
PORTAL_MINT_WORKER_URL=

# Server-only Base RPC used for live Coinbase EAS attestation lookup.
BASE_RPC_URL=
PORTAL_ATTESTATION_MODE=mock

# Checkout stays hidden until public payment mode is set to checkout.
NEXT_PUBLIC_PORTAL_PAYMENT_MODE=mock
# Optional override for a controlled direct Base USDC Builder Code attribution test.
# Leave blank for the normal Thirdweb checkout path.
NEXT_PUBLIC_PORTAL_PAYMENT_FLOW=
# Fallback shown before runtime admin settings load.
NEXT_PUBLIC_PORTAL_PAYMENT_AMOUNT=5.00
NEXT_PUBLIC_PORTAL_PAYMENT_SELLER=0xd89A17cab674979A531657Cd426fC65aF29F8214
NEXT_PUBLIC_PORTAL_PAYMENT_TOKEN_ADDRESS=
NEXT_PUBLIC_PORTAL_PAYMENT_TOKEN_DECIMALS=6
NEXT_PUBLIC_BASE_BUILDER_CODE_DATA_SUFFIX=
# Optional comma-separated wallet allowlist for owner-only direct payment tests.
NEXT_PUBLIC_PORTAL_DIRECT_PAYMENT_ALLOWED_WALLETS=

# Set required only after the webhook and ledger table are configured.
PORTAL_PAYMENT_MODE=mock
PORTAL_PAYMENT_FLOW=
# Fallback used until /admin stores a runtime checkout price.
PORTAL_PAYMENT_AMOUNT=5.00
PORTAL_PAYMENT_SELLER=
PORTAL_PAYMENT_TOKEN_ADDRESS=
PORTAL_PAYMENT_TOKEN_DECIMALS=6
BASE_BUILDER_CODE_DATA_SUFFIX=
PORTAL_DIRECT_PAYMENT_ALLOWED_WALLETS=
THIRDWEB_PAYMENTS_WEBHOOK_SECRET=
# DynamoDB table with a string partition key named pk.
PORTAL_LEDGER_TABLE=
AWS_REGION=

# Required in production to open /admin.
ADMIN_BASIC_USER=
ADMIN_BASIC_PASSWORD=
